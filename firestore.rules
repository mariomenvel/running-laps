rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ────────────────────────────────────────────────────────────────────────
    // HELPERS
    // ────────────────────────────────────────────────────────────────────────

    function isSignedIn() {
      return request.auth != null;
    }

    // True when the requesting user is the document owner.
    function isOwner(uid) {
      return request.auth != null && request.auth.uid == uid;
    }

    // True when the requesting user has isAdmin: true on their profile.
    // Only the Firebase console or Admin SDK should ever set this field.
    function isAdmin() {
      return request.auth != null &&
             get(/databases/$(database)/documents/users/$(request.auth.uid))
               .data.isAdmin == true;
    }

    // True when the requesting user has a member document in the group.
    // Uses exists() which is billed as a read but avoids fetching the full doc.
    function isGroupMember(groupId) {
      return request.auth != null &&
             exists(/databases/$(database)/documents/groups/$(groupId)/members/$(request.auth.uid));
    }

    // True when the requesting user's member document has role admin or owner.
    function isGroupAdmin(groupId) {
      return request.auth != null &&
             get(/databases/$(database)/documents/groups/$(groupId)/members/$(request.auth.uid))
               .data.role in ['admin', 'owner'];
    }

    // True when the incoming document is not abnormally large.
    // Applied to user-facing creates to limit storage abuse.
    function isReasonableDocument() {
      return request.resource.data.keys().size() < 50;
    }

    // True when the document is both key-count-bounded and total-size-bounded.
    // Applied to group-level creates to prevent large document injection.
    function isSafeWrite() {
      return request.resource.data.keys().size() < 50
          && request.resource.data.toString().size() < 10000;
    }

    // ────────────────────────────────────────────────────────────────────────
    // users/{uid}
    // ────────────────────────────────────────────────────────────────────────
    match /users/{uid} {

      // Any signed-in user can read any profile document or run a query.
      // Required for:
      //   (a) Group ranking UI reads name / photoUrl / avatarConfig of other members.
      //   (b) UserLookupService queries users by email field when sending invites.
      allow read: if isSignedIn();

      // A user can create their own profile on first register / Google login.
      allow create: if isOwner(uid) && isReasonableDocument();

      // A user can update their own profile, but CANNOT set isAdmin on themselves.
      // Privilege escalation via the client must be impossible.
      allow update: if isOwner(uid) &&
                       !request.resource.data.diff(resource.data)
                         .affectedKeys().hasAny(['isAdmin']);

      // A user can delete their own account document (account deletion flow).
      allow delete: if isOwner(uid);

      // ── users/{uid}/trainings/{id} ─────────────────────────────────────────
      match /trainings/{trainingId} {
        // Reads allow any signed-in user.
        // WHY: GroupDetailRepository fetches members' training documents to
        //   compute group leaderboard rankings (cross-user read by design).
        // LIMITATION: Ideally reads should require shared-group membership, but
        //   Firestore rules have no way to query "does a group exist where both
        //   request.auth.uid and uid are members?" without a known groupId.
        //   PRODUCTION RECOMMENDATION: move ranking computation to a Cloud
        //   Function (Admin SDK) and restrict this rule to isOwner(uid) only.
        // Wear OS custom token pendiente (deuda técnica #2).
        // Hasta entonces solo el propietario puede leer sus propios trainings.
        allow read: if isOwner(uid);

        // Authenticated owner can delete their own trainings.
        allow delete: if isOwner(uid);

        // Authenticated owner can update their own trainings.
        // Wear OS watch (no Firebase Auth) may update only the 'tags' field on a
        // training it created, identified by source == "wear_os" and wear_uid == uid.
        allow update: if isOwner(uid)
            || (request.resource.data.source == "wear_os"
                && request.resource.data.get("wear_uid", "") == uid
                && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['tags']));

        // Authenticated owner can create normally.
        // Wear OS watch has no real Firebase Auth session — it stores the uid
        // in SharedPreferences and sends it as a document field. Allow create
        // when the document self-identifies as wear_os and declares the uid.
        // Field size limits prevent storage abuse regardless of auth path.
        allow create: if (isOwner(uid)
            || (request.resource.data.source == "wear_os"
                && request.resource.data.get("wear_uid", "") == uid))
            && request.resource.data.keys().size() < 20
            && request.resource.data.get("titulo", "").size() < 200
            && request.resource.data.get("series", []).size() < 500;
      }

      // ── users/{uid}/tags/{id} ──────────────────────────────────────────────
      match /tags/{tagId} {
        // Owner can read and write their own tags.
        // Wear OS custom token pendiente (deuda técnica #2).
        allow read: if isOwner(uid);
        allow create, update: if isOwner(uid)
            && request.resource.data.keys().size() < 10;
        allow delete: if isOwner(uid);
      }

      // ── users/{uid}/groups/{groupId} ───────────────────────────────────────
      match /groups/{groupId} {
        // Personal record of which groups the user belongs to.
        // InvitesRepository.acceptInvite() is called by the invitee themselves,
        // so isOwner(uid) is always satisfied during invite acceptance.
        allow read, write: if isOwner(uid);
      }

      // ── users/{uid}/templates/{id} ────────────────────────────────────────
      match /templates/{templateId} {
        // Personal training templates (features/templates). Strictly private.
        // Wear OS custom token pendiente (deuda técnica #2).
        allow read: if isOwner(uid);
        allow write: if isOwner(uid);
      }

      // ── users/{uid}/savedBlocks/{id} ──────────────────────────────────────
      match /savedBlocks/{blockId} {
        // Personal saved workout blocks. Strictly private to the owner.
        allow read, write: if isOwner(uid);
      }

      // ── users/{uid}/settings/{id} ──────────────────────────────────────────
      match /settings/{settingId} {
        // HomeConfigRepository reads and writes users/{uid}/settings/homeLayoutConfig
        // to persist the home dashboard widget layout (visibility, order, config).
        // Wear OS custom token pendiente (deuda técnica #2).
        allow read: if isOwner(uid);
        allow write: if isOwner(uid);
      }

      // ── users/{uid}/athleteSessions/{sessionId} ───────────────────────────
      match /athleteSessions/{sessionId} {
        // Planned sessions are private to the owner.
        // AthleteSessionRepository always reads/writes the current user's own sessions.
        allow read, write: if isOwner(uid);
      }

      // ── users/{uid}/result_notifications/{id} ──────────────────────────────
      match /aiCoachEvents/{eventId} {
        allow read, write: if isOwner(uid);
      }

      match /aiCoachFeedback/{weekStart} {
        allow read, write: if isOwner(uid);
      }

      match /result_notifications/{notifId} {
        // The owner reads and deletes their own reward notifications.
        allow read, delete: if isOwner(uid);

        // Updates (e.g. mark-as-read) are owner-only.
        allow update: if isOwner(uid);

        // ChallengeFinalizationService writes award notifications for winners
        // whose uid differs from the authenticated caller (cross-user create).
        // Content is non-sensitive (medal / badge award info).
        // toUid must match the document's parent uid to prevent cross-user spam.
        // TEMP: any signed-in user can create until Cloud Functions are available.
        // PRODUCTION: restrict to Admin SDK via Cloud Function only.
        allow create: if isSignedIn()
            && request.resource.data.keys().size() < 15
            && request.resource.data.get("type", "").size() < 50
            && request.resource.data.get("toUid", "") == uid;
      }
    }

    // ────────────────────────────────────────────────────────────────────────
    // groups/{groupId}
    // ────────────────────────────────────────────────────────────────────────
    match /groups/{groupId} {

      // Any signed-in user can read group documents.
      // Required to: discover groups, preview before joining, validate invites.
      allow read: if isSignedIn();

      // Any signed-in user can create a group (they become its owner).
      allow create: if isSignedIn() && isSafeWrite();

      // Only group admins / owners can rename, configure, or delete the group.
      allow update, delete: if isGroupAdmin(groupId);

      // Any signed-in user can increment memberCount by exactly 1 when joining
      // via invite code. Restricted to the 'memberCount' field and a +1 delta
      // to prevent arbitrary inflation.
      allow update: if isSignedIn() &&
                       request.resource.data.diff(resource.data)
                         .affectedKeys().hasOnly(['memberCount']) &&
                       request.resource.data.memberCount == resource.data.memberCount + 1;

      // ── groups/{groupId}/members/{uid} ─────────────────────────────────────
      match /members/{uid} {
        // All current group members can read the full roster (ranking, UI).
        // isOwner(uid) allows a user to check their own membership status
        // before joining (e.g. join-by-code flow reads the doc to avoid duplicate join).
        allow read: if isGroupMember(groupId) || isOwner(uid);

        // A user can create their own member doc (join / accept invite) or delete
        // it (leave). A group admin can do either for any member (kick / invite).
        allow delete: if isOwner(uid) || isGroupAdmin(groupId);
        allow create: if (isOwner(uid) || isGroupAdmin(groupId))
            && request.resource.data.keys().size() < 15;

        // Only admins may update member docs (set status=kicked, change role).
        // Prevents privilege escalation: without this restriction a member could
        // directly set role='owner' on their own doc and gain admin powers.
        allow update: if isGroupAdmin(groupId);
      }

      // ── groups/{groupId}/challenges/{id} ───────────────────────────────────
      match /challenges/{challengeId} {
        // Group members see all challenges in their group.
        // App-level admins also need read access to run:
        //   AdminRepository.collectionGroup('challenges').count()
        //   which spans ALL groups regardless of membership.
        allow read: if isGroupMember(groupId) || isAdmin();

        // Group admins can create any challenge.
        // Group members can also create auto-challenges seeded from system templates:
        // EnsureAutoChallengesService runs in member context and always sets
        // origin='template' + createdBy='system' — unblocks template challenge loading.
        allow create: if isGroupAdmin(groupId) ||
                         (isGroupMember(groupId) &&
                          request.resource.data.get('origin', '') == 'template' &&
                          request.resource.data.get('createdBy', '') == 'system');
        // Only admins may modify or remove challenges (finalization, medal awarding, deletion).
        allow update, delete: if isGroupAdmin(groupId);

        // ── groups/{groupId}/challenges/{id}/participants/{uid} ─────────────
        match /participants/{uid} {
          // All group members can read participant records (leaderboard display).
          // Admin collectionGroup query on 'participations' is also covered here
          // because isAdmin() implies the admin is authenticated.
          allow read: if isGroupMember(groupId) || isAdmin();

          // Each user writes and updates only their own participation record.
          // TrainingChallengeSyncService and AutoJoinService run in user context.
          allow update, delete: if isOwner(uid);
          allow create: if isOwner(uid)
              && request.resource.data.keys().size() < 20
              && request.resource.data.toString().size() < 2000;
        }
      }

      // ── groups/{groupId}/invites/{inviteId} ────────────────────────────────
      match /invites/{inviteId} {
        // Any signed-in user can read invites to validate a token before joining.
        // The user is not yet a member when they first open the invite link.
        allow read: if isSignedIn();

        // Only group admins can create, update, or revoke invites.
        allow write: if isGroupAdmin(groupId);

        // Any signed-in user can increment the uses counter by exactly 1 when
        // joining via code. Delta-locked to prevent replay/counter-inflation.
        allow update: if isSignedIn() &&
                         request.resource.data.diff(resource.data)
                           .affectedKeys().hasOnly(['uses']) &&
                         request.resource.data.uses == resource.data.uses + 1;
      }

      // ── groups/{groupId}/medals/{uid} ──────────────────────────────────────
      match /medals/{uid} {
        // Group members see each other's medal counts (gamification / social).
        allow read: if isGroupMember(groupId);

        // ChallengeFinalizationService (called by a group admin) writes medal
        // counts for winners. The recipient uid differs from the admin caller,
        // but isGroupAdmin() checks the caller's role, not uid.
        allow write: if isGroupAdmin(groupId);
      }

      // ── groups/{groupId}/medal_history/{id} ────────────────────────────────
      match /medal_history/{historyId} {
        // Medal history is visible to all group members (group social feed).
        allow read: if isGroupMember(groupId);

        // Written by ChallengeFinalizationService in admin context.
        allow write: if isGroupAdmin(groupId);
      }

      // ── groups/{groupId}/badges/{uid} ──────────────────────────────────────
      match /badges/{uid} {
        // Group members see each other's badge counts.
        allow read: if isGroupMember(groupId);

        // Written by ChallengeFinalizationService in admin context.
        allow write: if isGroupAdmin(groupId);
      }

      // ── groups/{groupId}/badge_history/{id} ────────────────────────────────
      match /badge_history/{historyId} {
        // Badge history is visible to all group members.
        allow read: if isGroupMember(groupId);

        // Written by ChallengeFinalizationService in admin context.
        allow write: if isGroupAdmin(groupId);
      }

      // ── groups/{groupId}/prefs/{uid} ───────────────────────────────────────
      match /prefs/{uid} {
        // Notification and display preferences are strictly private.
        // Even group admins cannot read or write other members' prefs.
        allow read, write: if isOwner(uid);
      }
    }

    // ────────────────────────────────────────────────────────────────────────
    // invite_codes/{code}
    // ────────────────────────────────────────────────────────────────────────
    // Flat lookup table: shortCode → { groupId, inviteId, expiresAt }.
    // Allows any authenticated user to resolve a code before they are a group
    // member. Writes are allowed to any signed-in user because:
    //   (a) Only group admins reach createInviteWithCode() in practice
    //       (the UI is gated behind _isOwner in GroupScreen).
    //   (b) The invite document in groups/{groupId}/invites/{id} (protected by
    //       isGroupAdmin) is written atomically in the same batch, so a rogue
    //       write to invite_codes pointing to a non-existent invite is harmless.
    // PRODUCTION RECOMMENDATION: Restrict write to isGroupAdmin(data.groupId)
    //   once Firestore supports accessing request.resource.data in top-level rules.
    match /invite_codes/{code} {
      allow read: if isSignedIn();
      // Restrict create: caller must be signed in and supply the required fields
      // with a bounded document size. The matching invite document in
      // groups/{groupId}/invites/{id} (protected by isGroupAdmin) is written
      // atomically in the same batch, so a rogue create here is low-risk but
      // field validation still prevents junk data accumulation.
      allow create: if isSignedIn()
          && request.resource.data.keys().hasAll(['groupId', 'inviteId'])
          && request.resource.data.keys().size() < 10;
      // Only the group admin who owns the invite can update or delete the lookup entry.
      allow update, delete: if isGroupAdmin(resource.data.groupId);
    }

    // ────────────────────────────────────────────────────────────────────────
    // wear_sessions/{code}
    // ────────────────────────────────────────────────────────────────────────
    // Short-lived QR auth session created by the Wear OS watch.
    // The watch is NOT yet authenticated when it creates the document, so
    // creates are intentionally open. The random 6-char code provides
    // sufficient entropy for a session that expires quickly.
    // PRODUCTION: Add cleanup via a Cloud Function TTL trigger (e.g. delete
    //   documents older than 5 minutes) and generate a real Firebase Custom
    //   Token server-side instead of forwarding the client ID token.
    match /wear_sessions/{code} {
      // Watch creates session before authentication — allow unauthenticated create.
      // Requires createdAt + status fields so TTL cleanup can target stale docs,
      // and caps document size to prevent abuse of the open create rule.
      allow create: if request.resource.data.keys().hasAll(['createdAt', 'status'])
          && request.resource.data.status == 'pending'
          && request.resource.data.keys().size() < 10
          && request.resource.data.get("createdAt", 0) is timestamp
          && request.resource.data.createdAt <= request.time + duration.value(10, 'm');

      // Only authenticated users (phone) can update (write the idToken).
      allow update: if isSignedIn();

      // Watch reads to check auth status — allow unauthenticated read.
      // Only recent sessions (created < 10 minutes ago) are readable to prevent
      // bots from enumerating historical session documents.
      allow read: if resource.data.createdAt > request.time - duration.value(10, 'm');

      // Only authenticated users can delete.
      allow delete: if isSignedIn();
    }

    // ────────────────────────────────────────────────────────────────────────
    // challenge_templates/{id}
    // ────────────────────────────────────────────────────────────────────────
    match /challenge_templates/{templateId} {
      // All signed-in users can browse templates when creating a challenge.
      allow read: if isSignedIn();

      // Only app-level admins (isAdmin: true) can create, update, or delete.
      allow write: if isAdmin();
    }

    // ────────────────────────────────────────────────────────────────────────
    // appConfig/{doc}
    // ────────────────────────────────────────────────────────────────────────
    // Configuración global de la app (AI Coach provider config, etc.)
    // Solo lectura para usuarios autenticados.
    // Solo escritura para administradores.
    match /appConfig/{docId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // ────────────────────────────────────────────────────────────────────────
    // global_challenges/{id}
    // ────────────────────────────────────────────────────────────────────────
    match /global_challenges/{challengeId} {
      // All signed-in users can read global challenges.
      allow read: if isSignedIn();

      // Only app-level admins can manage global challenges.
      allow write: if isAdmin();

      // ── global_challenges/{id}/participations/{uid} ───────────────────────
      match /participations/{uid} {
        // AdminRepository queries collectionGroup('participations') and checks
        // path.contains('global_challenges') to count global-challenge enrollment.
        // Global challenge participation is visible to all signed-in users
        // (consistent with global challenges themselves being public).
        allow read: if isSignedIn();

        // Each user writes and manages only their own participation record.
        allow update, delete: if isOwner(uid);
        allow create: if isOwner(uid)
            && request.resource.data.keys().size() < 20
            && request.resource.data.toString().size() < 2000;
      }
    }
  }
}
