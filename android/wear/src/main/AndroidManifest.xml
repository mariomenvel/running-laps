<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Declares this as a Wear OS app -->
    <uses-feature android:name="android.hardware.type.watch" />

    <!-- Wearable Data Layer requires waking the device -->
    <uses-permission android:name="android.permission.WAKE_LOCK" />

    <application
        android:label="@string/app_name"
        android:theme="@android:style/Theme.DeviceDefault">

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:label="@string/app_name">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!--
            TrainingDataService: woken by the Wearable Data Layer when the phone
            writes a DataItem to /training/metrics. Also handles any incoming
            messages on /training paths.
        -->
        <service
            android:name=".TrainingDataService"
            android:exported="true">
            <intent-filter>
                <action android:name="com.google.android.gms.wearable.DATA_CHANGED" />
                <action android:name="com.google.android.gms.wearable.MESSAGE_RECEIVED" />
                <data
                    android:scheme="wear"
                    android:host="*"
                    android:pathPrefix="/training" />
            </intent-filter>
        </service>

    </application>

</manifest>
