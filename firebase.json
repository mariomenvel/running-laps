{
  "hosting": {
    "public": "hosting",
    "cleanUrls": true,
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "redirects": [
      { "source": "/landing.html", "destination": "/", "type": 301 },
      { "source": "/landing", "destination": "/", "type": 301 }
    ],
    "rewrites": [
      { "source": "/api/waitlist", "function": "joinWaitlist" }
    ],
    "headers": [
      {
        "source": "/assets/**",
        "headers": [
          { "key": "Cache-Control", "value": "public, max-age=604800, stale-while-revalidate=86400" }
        ]
      },
      {
        "source": "**/*.@(webp|png|ico|woff2)",
        "headers": [
          { "key": "Cache-Control", "value": "public, max-age=604800, stale-while-revalidate=86400" }
        ]
      }
    ]
  },
  "firestore": {
    "rules": "firestore.rules",
    "indexes": "firestore.indexes.json"
  },
  "functions": {
    "source": "functions",
    "predeploy": [
      "npm --prefix \"$RESOURCE_DIR\" run build"
    ]
  },
  "flutter": {
    "platforms": {
      "android": {
        "default": {
          "projectId": "running-laps-mario-2025",
          "appId": "1:461355077893:android:ff9a05022ee4fa36bca76c",
          "fileOutput": "android/app/google-services.json"
        }
      },
      "dart": {
        "lib/firebase_options.dart": {
          "projectId": "running-laps-mario-2025",
          "configurations": {
            "android": "1:461355077893:android:ff9a05022ee4fa36bca76c",
            "ios": "1:461355077893:ios:58b7b62266a979adbca76c",
            "macos": "1:461355077893:ios:58b7b62266a979adbca76c",
            "web": "1:461355077893:web:aaf52eb376db5091bca76c",
            "windows": "1:461355077893:web:87243a46d88aa3d5bca76c"
          }
        }
      }
    }
  }
}
